<Window x:Class="CrazyBattoSoftwareManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CrazyBatto SOFTWARE MANAGER"
        Width="1680"
        Height="1050"
        MinWidth="1280"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBackground}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="295" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource BrushSidebarBg}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
            <Grid Margin="{StaticResource PaddingMedium}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- LOGO & PROFIL -->
                <Border Width="220" Height="190" HorizontalAlignment="Center" Background="{StaticResource BrushCardBg}" 
                        CornerRadius="{StaticResource CornerRadiusLarge}" BorderBrush="#DDE6F2" BorderThickness="1">
                    <Grid>
                        <Ellipse Width="134" Height="134" Stroke="{StaticResource BrushPrimary}" StrokeThickness="8" 
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="CB" FontSize="34" FontWeight="Black" Foreground="{StaticResource BrushPrimary}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- NAVIGATION -->
                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <Button Style="{StaticResource NavButton}" Background="#EAF5FF" BorderBrush="{StaticResource BrushAccent}" Content="Dashboard" />
                    <Button Style="{StaticResource NavButton}" Content="Plugins" />
                    <Button Style="{StaticResource NavButton}" Content="Windows Tweaks" />
                    <Button Style="{StaticResource NavButton}" Content="System Health" />
                    <Button Style="{StaticResource NavButton}" Content="ASUS Diagnose" />
                    <Button Style="{StaticResource NavButton}" Content="Corsair Center" />
                    <Button Style="{StaticResource NavButton}" Content="Wasserkuehlung" />
                    <Button Style="{StaticResource NavButton}" Content="Reports" />
                    <Button Style="{StaticResource NavButton}" Content="Overlay" />
                    <Button Style="{StaticResource NavButton}" Content="Discord" />
                    <Button Style="{StaticResource NavButton}" Content="BIOS und Treiber" />
                    <Button Style="{StaticResource NavButton}" Content="Einstellungen" />
                </StackPanel>

                <!-- SYSTEM STATUS PANEL -->
                <Border Grid.Row="2" Background="{StaticResource BrushCardBg}" CornerRadius="{StaticResource CornerRadiusMedium}" 
                        BorderBrush="#DDE6F2" BorderThickness="1" Padding="{StaticResource PaddingMedium}">
                    <StackPanel>
                        <TextBlock Text="SYSTEM STATUS" FontSize="{StaticResource FontSizeSmall}" FontWeight="Bold" Foreground="{StaticResource BrushText}" />
                        <TextBlock Text="Alle Systeme laufen stabil." FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource BrushSuccess}" Margin="0,10,0,0" />
                        <TextBlock Text="Core Dashboard aktiv" FontSize="{StaticResource FontSizeSmall}" Foreground="{StaticResource BrushTextLight}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="350" />
                <RowDefinition Height="*" />
                <RowDefinition Height="74" />
            </Grid.RowDefinitions>

            <!-- HEADER WITH DRAGON -->
            <Border Grid.Row="0" Background="{StaticResource BrushCardBg}" BorderBrush="{StaticResource BrushBorder}" 
                    BorderThickness="0,0,0,1" ClipToBounds="True">
                <Grid Background="{StaticResource GradientHeader}">
                    <!-- Background Pattern -->
                    <Canvas Opacity="0.08" IsHitTestVisible="False">
                        <Ellipse Width="150" Height="55" Canvas.Left="10" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="125" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="240" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="355" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="470" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="585" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="700" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="815" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="930" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Ellipse Width="150" Height="55" Canvas.Left="1045" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                    </Canvas>

                    <!-- Hero Content -->
                    <StackPanel VerticalAlignment="Center" Margin="58,0,0,0">
                        <TextBlock Text="CrazyBatto" FontSize="{StaticResource FontSizeHero}" FontWeight="Black" Foreground="{StaticResource BrushPrimary}" />
                        <TextBlock Text="SOFTWARE MANAGER" FontSize="{StaticResource FontSizeXLarge}" FontWeight="Black" Foreground="{StaticResource BrushAccent}" />
                        <TextBlock Text="FUER GAMING PCs" FontSize="{StaticResource FontSizeLarge}" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}" />
                        <TextBlock Text="Optimieren. Ueberwachen. Diagnostizieren." FontSize="17" Foreground="{StaticResource BrushText}" Margin="0,20,0,0" />
                        <TextBlock Text="Alles in einer Software." FontSize="17" Foreground="{StaticResource BrushText}" Margin="0,5,0,0" />
                    </StackPanel>

                    <!-- DRAGON DECORATION RIGHT -->
                    <Canvas HorizontalAlignment="Right" VerticalAlignment="Center" Width="450" Height="280" Margin="0,0,30,0" Opacity="0.85">
                        <!-- Dragon Head -->
                        <Ellipse Width="120" Height="100" Canvas.Left="280" Canvas.Top="20" Stroke="{StaticResource BrushPrimary}" StrokeThickness="3" Fill="#F0F4FF" />
                        
                        <!-- Dragon Snout -->
                        <Path Stroke="{StaticResource BrushPrimary}" StrokeThickness="3" Fill="Transparent" 
                              Data="M 340 60 L 380 50 L 390 70 L 380 90 Z" />
                        
                        <!-- Dragon Eyes -->
                        <Ellipse Width="12" Height="12" Canvas.Left="300" Canvas.Top="45" Fill="{StaticResource BrushAccent}" />
                        <Ellipse Width="12" Height="12" Canvas.Left="330" Canvas.Top="35" Fill="{StaticResource BrushAccent}" />
                        
                        <!-- Dragon Horns -->
                        <Path Stroke="{StaticResource BrushPrimary}" StrokeThickness="2.5" 
                              Data="M 300 15 Q 290 0, 295 -15 M 340 5 Q 350 -10, 360 -20" />
                        
                        <!-- Dragon Neck to Body -->
                        <Path Stroke="{StaticResource BrushPrimary}" StrokeThickness="3" Fill="Transparent"
                              Data="M 320 115 Q 280 140, 260 180 Q 240 220, 200 240" StrokeLineCap="Round" />
                        
                        <!-- Dragon Wings -->
                        <Path Stroke="{StaticResource BrushPrimary}" StrokeThickness="2.5" Fill="#E5F2FF" Opacity="0.6"
                              Data="M 310 120 Q 280 100, 240 80 Q 220 100, 250 140 Q 280 130, 310 120" />
                        
                        <Path Stroke="{StaticResource BrushPrimary}" StrokeThickness="2.5" Fill="#E5F2FF" Opacity="0.6"
                              Data="M 330 110 Q 370 95, 410 85 Q 420 110, 390 145 Q 360 125, 330 110" />
                        
                        <!-- Dragon Body Curves -->
                        <Path Stroke="{StaticResource BrushAccent}" StrokeThickness="2" Fill="Transparent"
                              Data="M 200 240 Q 150 260, 120 200 Q 100 180, 80 220" StrokeLineCap="Round" StrokeLineJoin="Round" />
                        
                        <!-- Dragon Tail -->
                        <Path Stroke="{StaticResource BrushPrimary}" StrokeThickness="3" Fill="Transparent"
                              Data="M 80 220 Q 40 240, 20 280 Q 10 290, 30 300 Q 50 280, 80 260" StrokeLineCap="Round" />
                        
                        <!-- Tail Accent (Blue) -->
                        <Path Stroke="{StaticResource BrushAccent}" StrokeThickness="2" Fill="Transparent"
                              Data="M 70 230 Q 50 250, 35 285" StrokeLineCap="Round" />
                        
                        <!-- Spikes along back -->
                        <Line X1="270" Y1="160" X2="260" Y2="140" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Line X1="230" Y1="200" X2="220" Y2="175" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                        <Line X1="150" Y1="250" X2="140" Y2="225" Stroke="{StaticResource BrushPrimary}" StrokeThickness="2" />
                    </Canvas>
                </Grid>
            </Border>

            <!-- CARDS GRID -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <UniformGrid Columns="3" Margin="12">
                    <!-- Dashboard Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="DASHBOARD" />
                            <Border Height="138" Margin="{StaticResource MarginMedium}" Background="{StaticResource BrushPrimary}" CornerRadius="{StaticResource CornerRadiusSmall}" />
                        </StackPanel>
                    </Border>

                    <!-- System Health Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="SYSTEM HEALTH" />
                            <TextBlock Style="{StaticResource TextBody}" Text="Startup Health Check     OK" Foreground="{StaticResource BrushSuccess}" Margin="0,10,0,0" />
                            <TextBlock Style="{StaticResource TextBody}" Text="Windows Zustand         GUT" Foreground="{StaticResource BrushSuccess}" Margin="0,8,0,0" />
                            <TextBlock Style="{StaticResource TextBody}" Text="Fehlerlogs der letzten 24h    2" Foreground="{StaticResource BrushWarning}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Plugins Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="PLUGINS" />
                            <TextBlock Style="{StaticResource TextBody}" Text="Plugin-Verwaltung" Margin="0,18,0,0" />
                            <TextBlock Style="{StaticResource TextSmall}" Text="Plugin-Updates verfügbar: 3" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Windows Tweaks Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="WINDOWS TWEAKS" />
                            <TextBlock Style="{StaticResource TextBody}" Text="Windows Optimierung" Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ASUS Diagnose Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="ASUS DIAGNOSE" Foreground="{StaticResource BrushError}" />
                            <TextBlock Style="{StaticResource TextBody}" Text="ASUS Diagnose" Margin="0,18,0,0" />
                            <TextBlock Style="{StaticResource TextSmall}" Text="Fehler erkannt!" Foreground="{StaticResource BrushError}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Wasserkuehlung Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="WASSERKUEHLUNG" />
                            <TextBlock Style="{StaticResource TextBody}" Text="D5 NEXT Monitoring" Margin="0,18,0,0" />
                            <TextBlock Style="{StaticResource TextSmall}" Text="Kühlflüssigkeit: 45°C" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Overlay Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="OVERLAY" />
                            <TextBlock Style="{StaticResource TextBody}" Text="Desktop Overlay" Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- BIOS & Treiber Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="BIOS UND TREIBER" />
                            <TextBlock Style="{StaticResource TextBody}" Text="BIOS Version             3102" Margin="0,18,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- System Info Card -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource TextHeading}" Text="DEIN SYSTEM" />
                            <TextBlock Style="{StaticResource TextBody}" Text="ASUS ROG Crosshair X870E Glacial" FontWeight="Bold" Margin="0,18,0,0" />
                            <TextBlock Style="{StaticResource TextSmall}" Text="AMD Ryzen 7 9800X3D" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </ScrollViewer>

            <!-- FOOTER -->
            <Border Grid.Row="2" Background="{StaticResource BrushPrimary}" CornerRadius="{StaticResource CornerRadiusLarger},28,0,0" 
                    Margin="14,0,14,0" Padding="{StaticResource PaddingLarge},10">
                <TextBlock Style="{StaticResource TextTitle}" 
                           Text="CrazyBatto SOFTWARE MANAGER - EIN TOOL FUER DEIN GAMING SETUP" 
                           VerticalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</Window>
