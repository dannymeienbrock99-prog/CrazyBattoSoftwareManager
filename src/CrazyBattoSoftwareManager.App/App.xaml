<!-- App.xaml - Zentrale Ressourcen -->
<Application x:Class="CrazyBattoSoftwareManager.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- FARBEN -->
        <Color x:Key="ColorPrimary">#111827</Color>
        <Color x:Key="ColorAccent">#1E9BFF</Color>
        <Color x:Key="ColorBackground">#EEF3F8</Color>
        <Color x:Key="ColorCardBg">#FFFFFF</Color>
        <Color x:Key="ColorSidebarBg">#F8FAFC</Color>
        <Color x:Key="ColorBorder">#DAE3EF</Color>
        <Color x:Key="ColorSuccess">#16A34A</Color>
        <Color x:Key="ColorWarning">#F59E0B</Color>
        <Color x:Key="ColorError">#B91C1C</Color>
        <Color x:Key="ColorText">#374151</Color>
        <Color x:Key="ColorTextLight">#6B7280</Color>

        <!-- FARB-BRUSHES -->
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}" />
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}" />
        <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackground}" />
        <SolidColorBrush x:Key="BrushCardBg" Color="{StaticResource ColorCardBg}" />
        <SolidColorBrush x:Key="BrushSidebarBg" Color="{StaticResource ColorSidebarBg}" />
        <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}" />
        <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
        <SolidColorBrush x:Key="BrushError" Color="{StaticResource ColorError}" />
        <SolidColorBrush x:Key="BrushText" Color="{StaticResource ColorText}" />

        <!-- GRADIENT -->
        <LinearGradientBrush x:Key="GradientHeader" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#F6FAFF" Offset="0.45" />
            <GradientStop Color="#E5F2FF" Offset="1" />
        </LinearGradientBrush>

        <!-- ABSTÄNDE & GRÖSSEN -->
        <Thickness x:Key="PaddingSmall">8</Thickness>
        <Thickness x:Key="PaddingMedium">16</Thickness>
        <Thickness x:Key="PaddingLarge">24</Thickness>
        <Thickness x:Key="MarginSmall">0,5,0,0</Thickness>
        <Thickness x:Key="MarginMedium">0,12,0,12</Thickness>
        <Thickness x:Key="MarginCard">8</Thickness>

        <sys:Double x:Key="CornerRadiusSmall">8</sys:Double>
        <sys:Double x:Key="CornerRadiusMedium">16</sys:Double>
        <sys:Double x:Key="CornerRadiusLarge">18</sys:Double>
        <sys:Double x:Key="CornerRadiusLarger">28</sys:Double>

        <!-- SCHRIFTARTEN -->
        <sys:Double x:Key="FontSizeSmall">12</sys:Double>
        <sys:Double x:Key="FontSizeMedium">14</sys:Double>
        <sys:Double x:Key="FontSizeBody">16</sys:Double>
        <sys:Double x:Key="FontSizeHeading">18</sys:Double>
        <sys:Double x:Key="FontSizeTitle">22</sys:Double>
        <sys:Double x:Key="FontSizeLarge">26</sys:Double>
        <sys:Double x:Key="FontSizeXLarge">34</sys:Double>
        <sys:Double x:Key="FontSizeHero">70</sys:Double>

        <!-- BUTTON STYLES -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="{StaticResource MarginSmall}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="{StaticResource PaddingMedium},0,0,0" />
            <Setter Property="Background" Value="{StaticResource BrushCardBg}" />
            <Setter Property="BorderBrush" Value="#E4EAF2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="{StaticResource FontSizeMedium}" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF5FF" />
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- CARD STYLE -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushCardBg}" />
            <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLarge}" />
            <Setter Property="BorderBrush" Value="#DDE6F2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{StaticResource PaddingMedium}" />
            <Setter Property="Margin" Value="{StaticResource MarginCard}" />
        </Style>

        <!-- TEXTBLOCK STYLES -->
        <Style x:Key="TextHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{StaticResource BrushPrimary}" />
        </Style>

        <Style x:Key="TextTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="TextBody" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
            <Setter Property="Foreground" Value="{StaticResource BrushText}" />
        </Style>

        <Style x:Key="TextSmall" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextLight}" />
        </Style>
    </Application.Resources>
</Application>
